    <string name="tutorial_welcome_title">Meet your screenshot command center</string>
    <string name="tutorial_welcome_description">Snapify watches new screenshots, keeps the useful ones close, and helps temporary captures disappear on schedule.</string>
    <string name="tutorial_welcome_highlight">Everything starts in one focused feed instead of a crowded camera roll.</string>
    <string name="tutorial_feed_title">See what needs your attention</string>
    <string name="tutorial_feed_description">Filter marked, kept, and unmarked captures, then open any item for a closer look.</string>
    <string name="tutorial_feed_highlight">Clear status cues make every keep or delete decision intentional.</string>
    <string name="tutorial_modes_title">Choose your cleanup rhythm</string>
    <string name="tutorial_modes_description">Use automatic mode for timed cleanup or manual mode when every screenshot needs a deliberate decision.</string>
    <string name="tutorial_modes_highlight">You stay in control: change the mode or deletion timer whenever your workflow changes.</string>
    <string name="tutorial_settings_title">Make Snapify feel like yours</string>
    <string name="tutorial_settings_description">Tune appearance, language, monitored folders, notifications, and cleanup behavior from Settings.</string>
    <string name="tutorial_settings_highlight">Start with the defaults, then shape the app around the way you capture and organize.</string>
